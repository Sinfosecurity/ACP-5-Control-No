# ============================================================
# NYC DOB Filing Lookup — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL=postgresql://user:password@localhost:5432/nyc_dob_lookup
# For Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# --- NYC Open Data (Socrata) ---
# Optional: get a free app token at https://data.cityofnewyork.us/profile/app_tokens
NYC_OPEN_DATA_APP_TOKEN=

# --- Playwright ---
# Set to "true" to run Playwright in headless mode (recommended for production)
PLAYWRIGHT_HEADLESS=true
# Timeout in ms for Playwright operations
PLAYWRIGHT_TIMEOUT=30000
# Path to save Playwright screenshots (relative to project root)
PLAYWRIGHT_SCREENSHOT_DIR=./tmp/screenshots

# --- Rate Limiting ---
# Max requests per window per IP
RATE_LIMIT_MAX=20
# Window in ms (default: 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# --- App ---
NEXT_PUBLIC_APP_NAME="NYC DOB Filing Lookup"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
