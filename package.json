{
  "name": "nyc-dob-lookup",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node scripts/migrate.js",
    "playwright:install": "playwright install chromium",
    "test:unit": "node scripts/test-normalizer.js",
    "test:integration": "node scripts/test-search.js",
    "test:asbestos": "node scripts/test-asbestos.js",
    "test": "npm run test:unit",
    "validate-env": "node -e \"require('./src/lib/env.ts').validateEnv()\"",
    "docker:build": "docker build -t nyc-dob-lookup .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "zod": "^3.23.6",
    "pg": "^8.11.5",
    "@types/pg": "^8.11.5",
    "playwright": "^1.43.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "papaparse": "^5.4.1",
    "@types/papaparse": "^5.3.14"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3"
  }
}
